{
  "name": "rwa-oracle-feeder",
  "version": "2.0.0",
  "description": "Production RWA Oracle — StarkNet price feeder + Admin API. Real blockchain, real data, zero mocks.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:server\"",
    "dev": "ts-node --transpile-only src/index.ts",
    "dev:server": "ts-node --transpile-only src/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --transpile-only prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "starknet": "^6.23.1",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "winston": "^3.17.0",
    "p-retry": "^6.2.1",
    "@prisma/client": "^5.22.0",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1",
    "concurrently": "^9.1.2",
    "nodemailer": "^6.9.15",
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^5.22.0",
    "typescript": "^5.7.3",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
