{
  "name": "starknet-rwa-backend",
  "version": "1.0.0",
  "description": "Backend API and event listener for Starknet RWA protocol",
  "main": "dist/server.js",
  "scripts": {
    "start": "ts-node src/server.ts",
    "listen": "ts-node src/event-listener.ts",
    "dev": "concurrently \"npm run start\" \"npm run listen\"",
    "build": "tsc"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.16.0",
    "starknet": "^6.11.0",
    "dotenv": "^16.4.5",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "nodemailer": "^8.0.1",
    "mixpanel": "^0.18.0",
    "@amplitude/node": "^1.10.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/ws": "^8.5.10",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "@types/nodemailer": "^6.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "concurrently": "^8.2.2"
  }
}
